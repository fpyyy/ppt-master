{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PPT Master LayoutSpec v2",
  "type": "object",
  "required": ["slides"],
  "properties": {
    "design_tokens": {
      "type": "object"
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["slide_type", "content", "constraints", "capacity", "overflow_policy"],
        "properties": {
          "id": { "type": "string" },
          "slide_type": {
            "type": "string",
            "enum": [
              "cover",
              "toc",
              "section",
              "single_content",
              "two_column",
              "image_with_caption",
              "comparison_table",
              "timeline",
              "hub_spoke",
              "card_grid",
              "pipeline",
              "icon_text_list"
            ]
          },
          "content": { "type": "object" },
          "constraints": { "type": "array" },
          "capacity": { "type": "object" },
          "overflow_policy": { "type": "object" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
